# --- 1. FIREBASE CONFIGURATION ---
# Find these values inside: src/firebase.ts
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

VITE_ADMIN_EMAIL=your_admin_email@example.com
# EmailJS Configuration
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

VITE_ADMIN_PATH=your_secret_admin_path
VITE_API_BASE=http://localhost:3000

# SECURITY KEYS (REQUIRED FOR UPLOADS)
# Get key from: https://api.imgbb.com/
VITE_IMGBB_API_KEY=your_imgbb_api_key
# Must match process.env.ADMIN_SECRET in Vercel
VITE_ADMIN_SECRET=your_admin_secret_here

# AI CHATBOT KEY
# Get key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
